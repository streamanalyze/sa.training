-- bar plot, scatter plot, line plot, pie chart

//plot: Pie chart
{
  "apple": 10,
  "bear": 20,
  "citrus": 30
};

-- more plot options with multi plot

//plot: Multi plot
{'sa_plot': 'Line plot', 'memory': 200};
select [sin(x), cos(x)]
  from Number x
 where x in 10*heartbeat(.02)
 limit 400;

//plot: Multi plot
{ "sa_plots":[
  {'sa_plot': 'Line plot', 'memory': 200},
  {'sa_plot': 'Scatter plot', 'memory': 200}
]};
select [sin(x)*sin(x/30), cos(x)*cos(x/30)]
  from Number x
 where x in 20*heartbeat(.01)
 limit 600;


-- -----------------
-- Testing
-- -----------------

-- Query-based testing
validate "square root"
   check sqrt(4)  => 2
   check sqrt(0)  => 0
   check sqrt(-1) => null;

-- Bag value expressions
validate "bagged result"
   check range(3)
         => values 1,2,3;

-- Insignificant order
validate "insignificant bag order"
   check range(3)
         => values 3,1,2;

-- Tuple notation for tuple values
validate "tuple valued result"
   check divide(7,5) => (1,2);

-- Rounding numerical values
validate "square root"
   check roundto(sqrt(2),3)
         => 1.414;

-- Rounding collection elements
validate "rounding collection elements"
   check roundto([sqrt(2),'hello',12],2)
         => [1.41,'hello',12]
   check roundto([sqrt(2),12,[sqrt(3),'hello']],2)
         => [1.41,12,[1.73,'hello']]
   check roundto((values 12,'hello',sqrt(2)),2)
         => values 12,'hello',1.41;

-- Validating streams
validate 'finite streams'
   check extract(diota(0.1,1,3))
         => values 3,1,2           -- insignificant order
   check vectorof(diota(0.1,1,3))
         => [1,2,3];               -- order important

-- Validate infinite streams (use first_n)
validate 'infinite streams'
   check extract(first_n(heartbeat(0.1), 4))
         => values 0,0.1,0.2,0.3;

