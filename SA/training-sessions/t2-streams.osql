-- **************************************
-- Training session 2
-- Examples of stream functions in OSQL
-- **************************************

-- some functions that create synthetic streams
heartbeat(1);

simstream(0.1);

sample_stream("Hello stream",1);

-- A query theat takes a stream and outputs a stream
-- - a continouos query, CQ

//plot: Line plot
select sin(10*x)
  from Number x
 where x in heartbeat(0.05);

-- a CQ that acts as a filter
//plot: Line plot
select Stream of x
  from Number x
 where x in simstream(0.01)
   and x > 0.7;


-- -----------------
-- Combining streams
-- -----------------

-- Stream from diota, parameters (pace(s), start, end)
diota(2.0, 1, 5);   -- emit values 1-5 with 2.0s pace

-- Combine streams using merge
merge([diota(0.2,1,6), diota(0.5,1,5) * 10]);

-- Combine streams using pivot
pivot([diota(0.2,1,6), diota(0.5,1,5) * 10]);

-- Combine streams using zip
zip([diota(0.1,1,10), diota(1.0,1,10) * 10]);


-- -----------------
-- Timestamped streams
-- -----------------

-- timestamped stream
select ts(simstream(0.01)) limit 10;


create function my_timestamped_stream() -> stream of timeval
  as select stream of tv
       from real r, timeval tv
       where r in simstream(0.01)
         and tv = ts(r);

-- get timestamp and value from timestamped stream
select [t, val]
  from timeval tv, timeval t, real val
 where tv in my_timestamped_stream()
   and t = timestamp(tv)
   and val = value(tv)
 limit 10;


-- -----------------
-- Bus streams
-- -----------------

-- Bus stream with id/signal and value/payload
select Stream of 'S'||mod(i,3), i*10
  from Integer i
 where i in range(9);


-- Example of synthetic bus stream
--
-- One signal 's' every 0.1 seconds
-- One signal 't' every 0.5 seconds
--
create function bus_test_stream() -> stream of vector
  as select merge([s,t])
       from stream s, stream t
      where s = (select stream of [now(), "s", hb]   // stream "s"
                   from real hb
                  where hb in heartbeat(0.1))
        and t = (select stream of [now(), "t", hb]   // stream "t"
                   from real hb
                  where hb in heartbeat(0.5));

bus_test_stream();

-- Pivot signals in a bus stream (duplicate values)
pivot_events(['s','t'], bus_test_stream());


-- -----------------
-- Flows
-- -----------------

subscribe("my_flow");           -- Listen to "my flow"

publish(siota(1,4), "my_flow"); -- publish to “my_flow”

-- Don't forget to stop listening queries


-- Multiple subscribers
create function listener_1() -> Stream of Real
  as select Stream of r * 3.0 + 10.0
       from Real r
      where r in subscribe("r_flow");

create function listener_2() -> Stream of Real
  as select Stream of y
       from Real r, Real y
      where r in subscribe("r_flow")
        and y = r*r - sin(r);

//plot: Line plot
listener_1();

//plot: Line plot
listener_2();

-- Publish to "r_flow" and see that both subscribers
-- receive the data stream
sink(publish(timeout(simstream(0.5),10),"r_flow"));


-- Publish from queries
subscribe('fs1');

select res
  from Stream of Integer res,
       Stream of Integer base
 where base = siota(1,4)
   and res = publish(base * 2, 'fs1');


-- Subscribe in queries
select i * 10
  from Integer i
 where i in subscribe('fs2')
   and i > 2;

publish(siota(1,4),'fs2');


-- -----------------
-- Recorded data
-- -----------------

-- Write data to CSV file
create function my_stream() -> Stream of Vector
  as select Stream of [n]
       from Integer n
      where n in diota(0.1,1,10);

csv:write_file(sa_home() + "my_file.csv", my_stream());

-- Read data from CSV file
csv:file_stream(sa_home() + "my_file.csv");


-- -----------------
-- Plotting
